pipeline {

    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    parameters {

        choice(
            name: 'ACTION',
            choices: ['VALIDATE', 'UPDATESQL', 'UPDATE', 'ROLLBACK'],
            description: 'Select Liquibase operation'
        )

        choice(
            name: 'ENVIRONMENT',
            choices: ['DEV', 'STAGING', 'PRODUCTION'],
            description: 'Target deployment environment'
        )

        string(
            name: 'ROLLBACK_COUNT',
            defaultValue: '1',
            description: 'Rollback count (only for rollback action)'
        )
    }

    environment {

        REMOTE_HOST = "18.216.116.201"
        REMOTE_USER = "ubuntu"

        DB_HOST = "localhost"
        DB_PORT = "5432"
        DB_NAME = "appdb"
        DB_USER = "admin"
        DB_PASS = "admin"

        WORKDIR = "/home/ubuntu/liquibase-enterprise-poc"
    }

    stages {

        /* =========================
           CAPTURE AUDIT INFO
           ========================= */
        stage('Capture Build Info') {

            steps {
                script {

                    env.TRIGGERED_BY = currentBuild.getBuildCauses()[0]?.userId ?: "Unknown User"

                    env.AUDIT_LOG =
"""
================ LIQUIBASE AUDIT =================
Triggered By   : ${env.TRIGGERED_BY}
Action         : ${params.ACTION}
Environment    : ${params.ENVIRONMENT}
Rollback Count : ${params.ROLLBACK_COUNT}
Job Name       : ${env.JOB_NAME}
Build Number   : ${env.BUILD_NUMBER}
Build URL      : ${env.BUILD_URL}
===================================================
"""

                    currentBuild.description =
                        "User: ${env.TRIGGERED_BY} | Action: ${params.ACTION} | Env: ${params.ENVIRONMENT}"

                    echo env.AUDIT_LOG
                }
            }
        }

        /* =========================
           NOTIFICATION (EMAIL + SLACK)
           ========================= */
        stage('Notify Admin') {

            when {
                expression {
                    params.ENVIRONMENT in ['STAGING', 'PRODUCTION']
                }
            }

            steps {

                script {

                    def approvalUrl = "${env.BUILD_URL}input/"

                    def message =
"""
⚠ LIQUIBASE DEPLOYMENT APPROVAL REQUIRED

Triggered By   : ${env.TRIGGERED_BY}
Action         : ${params.ACTION}
Environment    : ${params.ENVIRONMENT}

JOB           : ${env.JOB_NAME}
BUILD         : ${env.BUILD_NUMBER}

👉 APPROVE HERE: ${approvalUrl}
"""

                    // EMAIL
                    emailext(
                        to: "rehan.ali9325@gmail.com",
                        subject: "🚨 APPROVAL REQUIRED - ${params.ENVIRONMENT} Liquibase Deployment",
                        body: message
                    )

                    // SLACK
                    slackSend(
                        channel: "#deployments",
                        color: "#FF9900",
                        message: message
                    )
                }
            }
        }

        /* =========================
           APPROVAL GATE (FIXED)
           ========================= */
        stage('Approval Gate') {

            when {
                expression {
                    params.ENVIRONMENT in ['STAGING', 'PRODUCTION']
                }
            }

            steps {

                timeout(time: 30, unit: 'MINUTES') {

                    script {

                        input message: """
${env.AUDIT_LOG}

⚠ APPROVAL REQUIRED

Approve to proceed or Abort to stop deployment
""",
                        ok: "APPROVE DEPLOYMENT",
                        submitter: "admin,newadmin,devops,release-manager"
                    }
                }
            }
        }

        /* =========================
           DEPLOYMENT STAGE
           ========================= */
        stage('Run Liquibase on EC2') {

            steps {

                sshagent(credentials: ['liquibase-ci-key']) {

                    sh """
                    ssh -T -o StrictHostKeyChecking=no ${REMOTE_USER}@${REMOTE_HOST} '
                        set -e

                        echo "========== DEPLOYMENT START =========="
                        echo "${env.AUDIT_LOG}"

                        cd ${WORKDIR}

                        echo "Liquibase Version:"
                        ./liquibase --version

                        echo "DB State:"
                        PGPASSWORD=${DB_PASS} psql -h ${DB_HOST} -U ${DB_USER} -d ${DB_NAME} -c "\\\\dt"

                        echo "VALIDATE:"
                        ./liquibase validate

                        echo "UPDATE SQL PREVIEW:"
                        ./liquibase updateSQL

                        echo "EXECUTING ACTION: ${params.ACTION}"

                        if [ "${params.ACTION}" = "VALIDATE" ]; then
                            ./liquibase validate

                        elif [ "${params.ACTION}" = "UPDATESQL" ]; then
                            ./liquibase updateSQL

                        elif [ "${params.ACTION}" = "UPDATE" ]; then
                            ./liquibase update

                        elif [ "${params.ACTION}" = "ROLLBACK" ]; then
                            ./liquibase rollbackCount ${params.ROLLBACK_COUNT}
                        fi

                        echo "HISTORY:"
                        ./liquibase history

                        echo "CHANGE COUNT:"
                        PGPASSWORD=${DB_PASS} psql -h ${DB_HOST} -U ${DB_USER} -d ${DB_NAME} -c "SELECT COUNT(*) FROM databasechangelog;"
                    '
                    """
                }
            }
        }
    }

    /* =========================
       POST ACTIONS
       ========================= */
    post {

        success {
            echo "======================================="
            echo "Liquibase Deployment SUCCESS"
            echo "======================================="
        }

        failure {
            echo "======================================="
            echo "Liquibase Deployment FAILED"
            echo "======================================="
        }

        aborted {
            echo "======================================="
            echo "Deployment ABORTED by user"
            echo "======================================="
        }

        always {
            echo "======================================="
            echo "FULL PIPELINE EXECUTION COMPLETED"
            echo "======================================="
        }
    }
}
